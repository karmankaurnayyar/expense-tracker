# ── Server ──────────────────────────────────────────────────
PORT=5000

# ── MySQL ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=expense_tracker

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────
# During development use * ; in production set your frontend URL
CORS_ORIGIN=*
